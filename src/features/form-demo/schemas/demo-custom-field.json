{
  "id": "custom-schema",
  "version": "1.0.0",
  "i18n": {
    "fr": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "cloudOption": {
            "type": "object",
            "title": "Option cloud",
            "properties": {
              "value": { "type": "string", "title": "Valeur", "default": "https://swapi.dev/api/people/1/" },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "title": "Date de mise à jour",
                "default": "2026-03-13T19:36:34.382Z"
              }
            }
          },
          "voiceNote": {
            "type": "object",
            "title": "Note vocale",
            "properties": {
              "value": { "type": "string", "title": "Texte" },
              "recordingUri": { "type": "string", "title": "Enregistrement" },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "title": "Date de mise à jour"
              }
            }
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          }
        }
      },
      "uiSchema": {
        "ui:submitButtonOptions": { "submitText": "Enregistrer" },
        "cloudOption": {
          "ui:field": "CloudDropdownPickerField",
          "ui:placeholder": "Sélectionner une option"
        },
        "voiceNote": {
          "ui:field": "VoiceInputField",
          "ui:placeholder": "Parlez ou saisissez votre note…"
        },
        "notes": {
          "ui:placeholder": "Saisissez vos notes…"
        }
      }
    },
    "en": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "cloudOption": {
            "type": "object",
            "title": "Cloud option",
            "properties": {
              "value": { "type": "string", "title": "Value", "default": "https://swapi.dev/api/people/1/" },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "title": "Last updated",
                "default": "2026-03-13T19:36:34.382Z"
              }
            }
          },
          "voiceNote": {
            "type": "object",
            "title": "Voice note",
            "properties": {
              "value": { "type": "string", "title": "Text" },
              "recordingUri": { "type": "string", "title": "Recording" },
              "updatedAt": {
                "type": "string",
                "format": "date-time",
                "title": "Last updated"
              }
            }
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          }
        }
      },
      "uiSchema": {
        "ui:submitButtonOptions": { "submitText": "Save" },
        "cloudOption": {
          "ui:field": "CloudDropdownPickerField",
          "ui:placeholder": "Select an option"
        },
        "voiceNote": {
          "ui:field": "VoiceInputField",
          "ui:placeholder": "Speak or type your note…"
        },
        "notes": {
          "ui:placeholder": "Enter your notes…"
        }
      }
    }
  }
}
