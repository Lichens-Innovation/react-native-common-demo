{
  "id": "simple-schema",
  "version": "1.0.0",
  "i18n": {
    "fr": {
      "schema": {
        "type": "object",
        "required": ["firstName", "lastName", "notes"],
        "properties": {
          "firstName": {
            "type": "string",
            "title": "Prénom",
            "description": "Votre prénom légal",
            "default": "Chuck"
          },
          "lastName": {
            "type": "string",
            "title": "Nom",
            "description": "Votre nom de famille",
            "default": "Norris"
          },
          "notes": {
            "type": "string",
            "title": "Notes"
          },
          "notesRecording": {
            "type": "string",
            "title": "Enregistrement des notes",
            "format": "uri",
            "default": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
          }
        }
      },
      "uiSchema": {
        "firstName": {
          "ui:placeholder": "ex. Jean"
        },
        "lastName": {
          "ui:placeholder": "ex. Dupont"
        },
        "notes": {
          "ui:placeholder": "Saisissez vos notes…"
        },
        "birthDate": {
          "ui:options": {
            "format": "YYYY-MM-DD"
          }
        },
        "notesRecording": {
          "ui:widget": "hidden",
          "ui:placeholder": "https://…"
        }
      }
    },
    "en": {
      "schema": {
        "type": "object",
        "required": ["firstName", "lastName", "notes"],
        "properties": {
          "firstName": {
            "type": "string",
            "title": "First Name",
            "description": "Your legal first name",
            "default": "Chuck"
          },
          "lastName": {
            "type": "string",
            "title": "Last Name",
            "description": "Your family name",
            "default": "Norris"
          },
          "notes": {
            "type": "string",
            "title": "Notes"
          },
          "notesRecording": {
            "type": "string",
            "title": "Notes Recording",
            "format": "uri",
            "default": "https://www.youtube.com/watch?v=dQw4w9WgXcQ"
          }
        }
      },
      "uiSchema": {
        "firstName": {
          "ui:placeholder": "e.g. John"
        },
        "lastName": {
          "ui:placeholder": "e.g. Doe"
        },
        "notes": {
          "ui:placeholder": "Enter your notes…"
        },
        "birthDate": {
          "ui:options": {
            "format": "YYYY-MM-DD"
          }
        },
        "notesRecording": {
          "ui:widget": "hidden",
          "ui:placeholder": "https://…"
        }
      }
    }
  }
}
