{
  "id": "custom-schema-demo",
  "version": "1.0.0",
  "i18n": {
    "fr": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "cloudOption": {
            "type": "string",
            "title": "Option cloud"
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          }
        }
      },
      "uiSchema": {
        "ui:submitButtonOptions": { "submitText": "Enregistrer" },
        "cloudOption": {
          "ui:field": "CloudDropdownPicker",
          "ui:placeholder": "Sélectionner une option"
        },
        "notes": {
          "ui:placeholder": "Saisissez vos notes…"
        }
      }
    },
    "en": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "cloudOption": {
            "type": "string",
            "title": "Cloud option"
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          }
        }
      },
      "uiSchema": {
        "ui:submitButtonOptions": { "submitText": "Save" },
        "cloudOption": {
          "ui:field": "CloudDropdownPicker",
          "ui:placeholder": "Select an option"
        },
        "notes": {
          "ui:placeholder": "Enter your notes…"
        }
      }
    }
  }
}
