{
  "id": "custom-schema-demo",
  "version": "1.0.0",
  "i18n": {
    "fr": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "cloudOption": {
            "type": "object",
            "title": "Option cloud",
            "properties": {
              "value": { "type": "string", "title": "Valeur", "default": "https://swapi.dev/api/people/1/" },
              "updatedAt": { "type": "string", "format": "date-time", "title": "Date de mise à jour", "default": "2026-03-13T19:36:34.382Z" }
            }
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          }
        }
      },
      "uiSchema": {
        "ui:submitButtonOptions": { "submitText": "Enregistrer" },
        "cloudOption": {
          "ui:field": "CloudDropdownPicker",
          "ui:placeholder": "Sélectionner une option"
        },
        "notes": {
          "ui:placeholder": "Saisissez vos notes…"
        }
      }
    },
    "en": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "cloudOption": {
            "type": "object",
            "title": "Cloud option",
            "properties": {
              "value": { "type": "string", "title": "Value", "default": "https://swapi.dev/api/people/1/" },
              "updatedAt": { "type": "string", "format": "date-time", "title": "Last updated", "default": "2026-03-13T19:36:34.382Z" }
            }
          },
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          }
        }
      },
      "uiSchema": {
        "ui:submitButtonOptions": { "submitText": "Save" },
        "cloudOption": {
          "ui:field": "CloudDropdownPicker",
          "ui:placeholder": "Select an option"
        },
        "notes": {
          "ui:placeholder": "Enter your notes…"
        }
      }
    }
  }
}
