{
  "id": "schema-with-grid",
  "version": "1.0.0",
  "i18n": {
    "fr": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "title": "Priorité (booléen en select)",
            "anyOf": [
              { "const": "low", "title": "Faible" },
              { "const": "high", "title": "Élevé" }
            ],
            "default": "low"
          },
          "done": {
            "type": "boolean",
            "title": "Terminé ?",
            "default": false
          }
        }
      },
      "uiSchema": {
        "notes": {
          "ui:placeholder": "Saisissez vos notes…"
        }
      }
    },
    "en": {
      "schema": {
        "type": "object",
        "required": ["notes"],
        "properties": {
          "notes": {
            "type": "string",
            "title": "Notes",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "title": "Priority (boolean as select)",
            "anyOf": [
              { "const": "low", "title": "Low" },
              { "const": "high", "title": "High" }
            ],
            "default": "low"
          },
          "done": {
            "type": "boolean",
            "title": "Done?",
            "default": false
          }
        }
      },
      "uiSchema": {
        "notes": {
          "ui:placeholder": "Enter your notes…"
        }
      }
    }
  }
}
