#!/usr/bin/env bash

# Exit immediately if any command fails
set -e

echo "Running lint..."
yarn format:fix
yarn lint:fix
yarn lint
echo "  -->  ✅ Lint completed"

# Prevent force push on protected branches
# This is a soft protection - can be bypassed with --no-verify if needed
while read local_ref local_sha remote_ref remote_sha
do
  branch=${remote_ref#refs/heads/}

  # Check if branch is protected (exact match) - use case for POSIX sh compatibility
  case "$branch" in
    main|master|development)
      # Skip deletion checks
      if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
        # Check if this is a force push
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
          echo "❌ Force push detected on protected branch: $branch"
          echo "   Attempting to push $local_sha on top of $remote_sha"
          echo ""
          echo "💡 If this is intentional, use: git push --force --no-verify"
          echo "   Otherwise, use: git pull --rebase"
          exit 1
        fi
      fi
      ;;
  esac
done

exit 0
